# Backend API URL
# Set this in Render dashboard under Environment Variables
VITE_API_URL=https://hirex-b.onrender.com

# Optional TURN server for WebRTC (Live AI Interview Broadcasting).
# STUN-only (the default) cannot traverse symmetric NATs or restrictive
# corporate firewalls — set these in production so recruiter/candidate pairs
# on such networks can still connect. Leave blank for local dev.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
